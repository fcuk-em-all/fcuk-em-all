# .env — copy to .env at the PROJECT ROOT (gitignored), or let bootstrap.sh
# export these. bootstrap runs compose with --project-directory=PROJECT_ROOT, so
# Docker Compose auto-loads the root .env and substitutes ${SF_BASE_DOMAIN} /
# ${SMB_USER} in the compose files.
SF_BASE_DOMAIN=fcuk-em-all.com
SMB_USER=media
